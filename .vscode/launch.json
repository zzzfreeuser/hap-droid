{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Debug DroidBot",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/droidbot-master/start.py",
      "cwd": "${workspaceFolder}/droidbot-master",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": [
                "--use-installed-app", 
                "--app-package", "com.zhihu.android",
                // "-o", "../out/zhihu_50",
                "-count", "50",
                "-is_emulator",
                // "-debug"
            ]
    },
    {
      "name": "Node: Debug HapTest (ts-node)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/HapTest-main/src/cli/cli.ts",
      "cwd": "${workspaceFolder}/HapTest-main",
      "runtimeArgs": [
        "-r",
        "ts-node/register"
      ],
      "args": [
        "-i", "com.example.distributedcontacts",
        "-o", "..\\out\\contacts",
        // "--debug",
        // "--policy", "replay",
        // "--report", "output\\photos\\2026-02-04-19-50-55",
      ],
      "sourceMaps": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Python: Debug convert",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/convert.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": [
        "-b", "com.baidu.netdisk.hmos",
        "-i", "expand_results/events",
        "-o", "test_results",
      ]
    },
    {
      "name": "Python: Debug expand",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/expand_event_view_tree.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": [
        "-i", "baidunetdisk_1000",
        "-o", "expand_results",
      ]
    },
    {
      "name": "Python: Debug dot to utg.js",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/dot_to_utg_js.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": [
        "out\\contacts\\2026-03-19-23-57-27\\ptg.dot"
      ]
    },
  ]
}