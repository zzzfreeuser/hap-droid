{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Debug DroidBot",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/droidbot-master/start.py",
      "cwd": "${workspaceFolder}/droidbot-master",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": [
                "--use-installed-app", 
                "--app-package", "com.zhihu.android",
                // "-o", "../out/zhihu_50",
                "-count", "50",
                "-is_emulator",
                // "-debug"
            ]
    },
    {
      "name": "Node: Debug HapTest (ts-node)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/HapTest-main/src/cli/cli.ts",
      "cwd": "${workspaceFolder}/HapTest-main",
      "runtimeArgs": [
        "-r",
        "ts-node/register"
      ],
      "args": [
        "-i", "cn.gov.tax.its.hm",
        "-o", "..\\out\\shui_llm_converted",
        // "--debug",
        "--policy", "replay",
        "--report", "D:\\GithubProjects\\hap-droid\\out\\shui_llm_30\\converts",
      ],
      "sourceMaps": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Python: Debug convert",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/convert.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": [
        "-b", "com.tencent.hm.qqmusic",
        "-i", "D:\\GithubProjects\\hap-droid\\out\\qqmusic_50\\events",
        "-o", "D:\\GithubProjects\\hap-droid\\out\\qqmusic_50\\test_results",
      ]
    },
    {
      "name": "Python: Debug expand",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/expand_event_view_tree.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": [
        "-i", "D:\\GithubProjects\\hap-droid\\out\\wechat_30_llm",
        "-o", "D:\\GithubProjects\\hap-droid\\out\\wechat_30_llm\\expands",
      ]
    },
    {
      "name": "Python: Debug dot to utg.js",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/dot_to_utg_js.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": [
        "out\\contacts\\2026-03-19-23-57-27\\ptg.dot"
      ]
    },
    {
      "name": "Python: Debug expand states to tree",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/expand_state_tree.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": [
        "--input", "D:\\GithubProjects\\hap-droid\\out\\xhs_20",
        // "-o", "D:\\GithubProjects\\hap-droid\\out\\xhs_20",
      ]
    },
  ]
}